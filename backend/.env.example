# Local: puedes usar nombres SUPABASE_* porque este archivo solo lo carga el backend.
# Netlify: usa PRIVATE_SUPABASE_URL y PRIVATE_SUPABASE_SERVICE_ROLE_KEY para que el prebuild del frontend no bloquee el despliegue.
SUPABASE_URL=https://tu-proyecto.supabase.co
# Obligatoria para login y paneles con RLS activo. Debe ser la key secreta/service_role, no la anon/public.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
SUPABASE_ANON_KEY=tu_anon_key # opcional para operaciones publicas si no usas SERVICE_ROLE_KEY
PORT=5000
AUTH_TOKEN_SECRET=define_un_secreto_largo_y_unico_de_al_menos_32_caracteres
# Admite varias URLs separadas por coma (ej: http://localhost:3000,https://tu-sitio.netlify.app)
FRONTEND_URL=http://localhost:3000
# Webhook de Make para automatizaciones al crear reservas
MAKE_WEBHOOK_URL=tu_webhook_de_make
